# .env.example — documents every environment variable the app needs.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file
# is committed so anyone cloning the repo knows what to configure.

APP_NAME="First Impression"
ENVIRONMENT="development"

# --- Embeddings (required) — RAG retrieval ---
# Voyage AI, free tier (3 req/min): https://dashboard.voyageai.com
VOYAGE_API_KEY=

# --- /report agent: the finalized model chain (required) ---
# ONE NVIDIA NIM key serves the whole quality-first agent chain
# (integrate.api.nvidia.com): GLM-5.2 → DeepSeek-V4-Pro → Nemotron-3-Ultra →
# Mistral-Medium-3.5. Free endpoints; get a key at https://build.nvidia.com.
# Chosen by a full-report benchmark + Artificial Analysis cross-check.
NVIDIA_API_KEY=

# --- Deep fallback (recommended) — different keys = real rate-limit insurance ---
# The NVIDIA models share one account quota, so Gemini/Groq back the chain up
# when that account throttles. Gemini also serves /ask and native synthesis.
# Make Gemini keys IN AI Studio (auto-enables the API): https://aistudio.google.com
# (a bare Cloud-Console key 403s). 2.0-flash is free-tier limit:0 and 2.5-flash
# 404s for new accounts — the pool uses gemini-3.1-flash-lite.
GEMINI_API_KEY=
GEMINI_SECONDACC_API_KEY=          # optional 2nd Google account = 2× Gemini headroom
GROQ_API_KEY=                      # optional — https://console.groq.com

# --- /ask endpoint LLM: "groq" (default), "gemini", or "anthropic" ---
LLM_PROVIDER=groq
ANTHROPIC_API_KEY=                 # only needed when LLM_PROVIDER=anthropic

# --- Observability (Phase 8, optional) — Langfuse tracing ---
# Set BOTH keys to trace each report (one span tree per run, every LLM call as a
# nested generation with tokens + latency). Absent → tracing is a hard no-op.
# Free project at https://cloud.langfuse.com. For the US region set
# LANGFUSE_HOST=https://us.cloud.langfuse.com (default is the EU host).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Legacy switch for the single-agent /report driver ("gemini" | "groq");
# the panel path (default) uses the NVIDIA pool chain regardless.
AGENT_PROVIDER=groq

# Optional overrides (defaults live in app/config.py):
# NVIDIA_GLM_MODEL=z-ai/glm-5.2
# GEMINI_POOL_MODEL=gemini-3.1-flash-lite   # Gemini fallback looping model
# GEMINI_AGENT_MODEL=gemini-3-flash-preview # native-synthesis fallback model
# EMBEDDING_MODEL=voyage-3.5
# MIN_RELEVANCE=0.45
# REQUEST_DELAY_SECONDS=1.0
