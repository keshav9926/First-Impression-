# .env.example — documents every environment variable the app needs.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file
# is committed so anyone cloning the repo knows what to configure.

APP_NAME="First Impression"
ENVIRONMENT="development"

# --- Phase 1: RAG ---
# Embeddings key (required) — https://dashboard.voyageai.com (free tier)
VOYAGE_API_KEY=

# Which LLM answers /ask questions: "gemini" (free tier, default) or "anthropic" (paid)
LLM_PROVIDER=gemini

# Gemini key (required when LLM_PROVIDER=gemini) — https://aistudio.google.com, no card needed
GEMINI_API_KEY=

# Claude key (required when LLM_PROVIDER=anthropic) — https://platform.claude.com
ANTHROPIC_API_KEY=

# Which LLM runs the /report agent: "gemini" or "groq".
# Groq recommended on free tier — its limits suit the agent's many calls far
# better than Gemini's ~20/day free quota. Key from https://console.groq.com.
AGENT_PROVIDER=gemini
GROQ_API_KEY=

# Optional overrides (defaults live in app/config.py):
# GEMINI_MODEL=gemini-2.5-flash            # /ask single calls
# GEMINI_AGENT_MODEL=gemini-2.5-flash      # /report agent (many calls; ~20/day free quota)
# CLAUDE_MODEL=claude-opus-4-8
# EMBEDDING_MODEL=voyage-3.5
# REQUEST_DELAY_SECONDS=1.0
